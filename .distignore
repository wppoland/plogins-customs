# Files excluded from the wp.org build. The plugin boots via the PSR-4 fallback
# in autoload.php, so Composer (/vendor + composer files) is not shipped.
/.git
/.github
/.gitignore
/.distignore
/node_modules
/tests
/vendor
/composer.json
/composer.lock
/phpstan.neon
/phpstan.neon.dist
/phpcs.xml
/phpcs.xml.dist
/SUBMISSION.md
.DS_Store
