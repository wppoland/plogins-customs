#. Plugin Name of the plugin
#: customs.php
msgid "Plogins Customs - EU Import Duty for WooCommerce"
msgstr "Plogins Customs - arancel de importación de la UE para WooCommerce"

#. Plugin URI of the plugin
#: customs.php
msgid "https://plogins.com/plogins-customs/"
msgstr "https://plogins.com/es/plogins-customs/"

#. Description of the plugin
#: customs.php
msgid ""
"Estimate and add the EU flat import duty (from 1 July 2026) as a clear "
"checkout line for parcels shipped into the EU from outside it."
msgstr ""
"Estima y añade el arancel fijo de importación de la UE (desde el 1 de julio "
"de 2026) como una línea clara en el pago para paquetes enviados a la UE "
"desde fuera de ella."

#. Author of the plugin
#: customs.php
msgid "WPPoland.com"
msgstr "WPPoland.com"

#. Author URI of the plugin
#: customs.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

#: customs.php:47
msgid ""
"Customs - EU Import Duty for WooCommerce requires WooCommerce to be active."
msgstr ""
"Customs - arancel de importación de la UE para WooCommerce requiere que "
"WooCommerce esté activo."

#: src/Admin/ProductFields.php:33
msgid "Customs tariff code"
msgstr "Código arancelario"

#: src/Admin/ProductFields.php:35
msgid ""
"Optional. Products sharing a code count as one EU import duty line. Leave "
"empty to group by category."
msgstr ""
"Opcional. Los productos que comparten un código cuentan como una línea de "
"arancel de importación de la UE. Déjalo vacío para agrupar por categoría."

#: src/Admin/ProductFields.php:36
msgid "e.g. 6109 (T-shirts)"
msgstr "p. ej. 6109 (camisetas)"

