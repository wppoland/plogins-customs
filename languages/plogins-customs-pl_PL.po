#. Plugin Name of the plugin
#: customs.php
msgid "Plogins Customs - EU Import Duty for WooCommerce"
msgstr "Plogins Customs - cło importowe UE dla WooCommerce"

#. Plugin URI of the plugin
#: customs.php
msgid "https://plogins.com/plogins-customs/"
msgstr "https://plogins.com/pl/plogins-customs/"

#. Description of the plugin
#: customs.php
msgid ""
"Estimate and add the EU flat import duty (from 1 July 2026) as a clear "
"checkout line for parcels shipped into the EU from outside it."
msgstr ""
"Szacuje i dodaje ryczałtowe cło importowe UE (od 1 lipca 2026 r.) jako "
"czytelną pozycję w kasie dla przesyłek wysyłanych do UE spoza niej."

#. Author of the plugin
#: customs.php
msgid "WPPoland.com"
msgstr "WPPoland.com"

#. Author URI of the plugin
#: customs.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

#: customs.php:47
msgid ""
"Customs - EU Import Duty for WooCommerce requires WooCommerce to be active."
msgstr ""
"Customs - cło importowe UE dla WooCommerce wymaga aktywnej wtyczki "
"WooCommerce."

#: src/Admin/ProductFields.php:33
msgid "Customs tariff code"
msgstr "Kod taryfy celnej"

#: src/Admin/ProductFields.php:35
msgid ""
"Optional. Products sharing a code count as one EU import duty line. Leave "
"empty to group by category."
msgstr ""
"Opcjonalnie. Produkty z tym samym kodem liczą się jako jedna linia cła "
"importowego UE. Pozostaw puste, aby grupować według kategorii."

#: src/Admin/ProductFields.php:36
msgid "e.g. 6109 (T-shirts)"
msgstr "np. 6109 (T-shirty)"

#: src/Admin/ProUpsell.php:82
msgid "Wkrótce"
msgstr "Wkrótce"

#: src/Admin/ProUpsell.php:82
msgid "Coming soon"
msgstr "Wkrótce"

